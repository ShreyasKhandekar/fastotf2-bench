# Scratch conversion output (large; regenerated each run)
.bench-scratch/
.venv/
.venv3.11/


# Built container images
container/*.sif
container/*.tar

# Per-run artifacts (large and/or host-specific) -- out/ is fully ignored. The small, curated
# subset needed to RE-RUN the analysis lives in the tracked analysis-data/ folder instead (see
# analysis-data/README.md); nothing needs to be picked out of out/ directly any more.
out/

# analysis-data/ IS tracked, but defensively ignore anything bulky/sensitive that should never
# land there even by accident (belt-and-suspenders; out/ above already blocks the source).
analysis-data/**/pq/
analysis-data/**/*.sif
analysis-data/**/*_logs/
analysis-data/**/slurm_logs/
analysis-data/**/run_logs/
analysis-data/**/*.pid
analysis-data/**/scratch/

# Python caches
__pycache__/
*.pyc

# Local secrets (SLURM account / mail user) — never commit
local_secrets.py

copilot/