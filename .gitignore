# Scratch conversion output (large; regenerated each run)
.bench-scratch/
.venv/
.venv3.11/


# Built container images
container/*.sif
container/*.tar

# Per-run artifacts that are large or host-specific.
# Kept (trackable): out/<run>/{config.json, run.sbatch, results.csv, job_id.txt, plots/}
out/**/scratch/
out/**/slurm_logs/
out/**/run_logs/

# Python caches
__pycache__/
*.pyc

# Local secrets (SLURM account / mail user) — never commit
local_secrets.py

copilot/